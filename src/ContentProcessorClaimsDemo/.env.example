# Replace each placeholder with the values for your own Entra app registrations and API host.
# See ../../docs/ConfigureAppAuthentication.md for how to create the SPA + API app registrations.
VITE_AAD_CLIENT_ID=<YOUR_SPA_APP_CLIENT_ID>
VITE_AAD_TENANT_ID=<YOUR_TENANT_ID>
VITE_AAD_API_SCOPE=api://<YOUR_API_APP_CLIENT_ID>/user_impersonation
# When unset, the Vite dev server proxies API calls to http://localhost:8000.
VITE_API_BASE_URL=
VITE_REDIRECT_URI=http://localhost:5173
